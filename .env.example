# OpenRouter API key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# AI Model (free models available - no payment needed)
# Options: google/gemma-3-12b-it:free, google/gemma-3-27b-it:free, meta-llama/llama-3.3-70b-instruct:free
AI_MODEL=google/gemma-3-12b-it:free
